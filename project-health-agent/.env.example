# ── LLM Provider ──────────────────────────────────────────────────
GEMINI_API_KEY=sk-gemini-your-key-here

# ── Database ─────────────────────────────────────────────────────
DATABASE_URL=sqlite:///./project_health.db

# ── LLM Configuration ────────────────────────────────────────────
LLM_MODEL=gemini-2.5-flash
LLM_MAX_TOKENS=1024

# ── Scheduler ────────────────────────────────────────────────────
SCHEDULER_ENABLED=false
SCHEDULER_CRON=0 9 * * 1

# ── File Storage ─────────────────────────────────────────────────
UPLOAD_DIR=uploads
REPORTS_DIR=reports

# ── App ──────────────────────────────────────────────────────────
APP_NAME=Project Health Agent
DEBUG=false
CORS_ORIGINS=["http://localhost:5173"]
