# ── LLM Provider ──────────────────────────────────────────────────
# Use either Gemini or Groq by setting the respective API key and model:
GEMINI_API_KEY=
GROQ_API_KEY=

# ── Database ─────────────────────────────────────────────────────
DATABASE_URL=sqlite:///./project_health.db

# ── LLM Configuration ────────────────────────────────────────────
# Example models: gemini-2.5-flash (Gemini), openai/gpt-oss-120b (Groq), llama-3.3-70b-versatile (Groq)
LLM_MODEL=openai/gpt-oss-120b
LLM_MAX_TOKENS=1024

# ── Scheduler ────────────────────────────────────────────────────
SCHEDULER_ENABLED=false
SCHEDULER_CRON=0 9 * * 1

# ── File Storage ─────────────────────────────────────────────────
UPLOAD_DIR=uploads
REPORTS_DIR=reports

# ── App ──────────────────────────────────────────────────────────
APP_NAME=Project Health Agent
DEBUG=false
CORS_ORIGINS=["http://localhost:5173"]
